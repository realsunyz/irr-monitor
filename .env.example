# Environment variables for IRR Monitor

# Required: Telegram Bot token from BotFather
TELEGRAM_BOT_TOKEN=

# Required: Channels to notify
# Supports @channel usernames or numeric IDs (e.g., -1001234567890)
TELEGRAM_CHANNELS=@your_channel

# Optional: Polling interval in seconds
POLL_INTERVAL=60

# Optional: State file path
STATE_FILE=/data/state.json
